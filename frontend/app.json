{
  "expo": {
    "name": "FamilyWallet",
    "slug": "familywallet",
    "owner": "dk12309453",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "familywallet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.dinesh.familywallet.v3",
      "permissions": ["RECEIVE_SMS", "READ_SMS"],
      "adaptiveIcon": {
        "backgroundColor": "#111827",
        "foregroundImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 6
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111827",
          "android": {
            "splash": {
              "image": "./assets/images/logo.png",
              "resizeMode": "contain",
              "backgroundColor": "#111827"
            }
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3941d515-b62e-4443-a44c-54bb0e027a0d"
      }
    }
  }
}
