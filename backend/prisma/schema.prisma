generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  name      String?
  avatar    String?
  createdAt DateTime @default(now())

  familyMembers FamilyMember[]
  expenses      Expense[]
  reviewQueue   ReviewQueue[]
  settings      Settings?
}

model Family {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  members  FamilyMember[]
  expenses Expense[]
}

model FamilyMember {
  id       String @id @default(uuid())
  userId   String
  familyId String
  role     String @default("Member") // "Owner", "Admin", "Member"

  user   User   @relation(fields: [userId], references: [id])
  family Family @relation(fields: [familyId], references: [id])

  @@unique([userId, familyId])
}

model Expense {
  id         String   @id @default(uuid())
  amount     Float
  merchant   String
  category   String
  visibility String // "Shared" or "Private"
  date       DateTime @default(now())
  notes      String?
  source     String   @default("Manual") // "Manual", "SMS", "OCR"

  userId   String
  familyId String?

  user   User    @relation(fields: [userId], references: [id])
  family Family? @relation(fields: [familyId], references: [id])
}

model Settings {
  id                  String  @id @default(uuid())
  userId              String  @unique
  autoShareGroceries  Boolean @default(true)
  autoShareFood       Boolean @default(true)
  autoShareRecharge   Boolean @default(true)
  trackGrocery        Boolean @default(true)
  trackFood           Boolean @default(true)
  trackRecharge       Boolean @default(true)
  trackDTH            Boolean @default(true)
  sharePrivateDetails Boolean @default(false)
  darkMode            Boolean @default(false)
  language            String  @default("English")

  user User @relation(fields: [userId], references: [id])
}

model ReviewQueue {
  id       String   @id @default(uuid())
  amount   Float
  merchant String
  category String
  date     DateTime @default(now())
  source   String // "SMS" or "Notification"
  status   String   @default("Pending") // "Pending", "Approved", "Ignored"

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
